root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.py]
indent_size = 4
indent_style = space
max_line_length = 88

[*.{yml,yaml}]
indent_size = 2
indent_style = space
max_line_length = off

[*.md]
max_line_length = off
indent_style = space
indent_size = 2

[*.toml]
indent_size = 2
indent_style = space

[*.json]
indent_size = 2
indent_style = space

[Dockerfile]
indent_style = space
indent_size = 4
